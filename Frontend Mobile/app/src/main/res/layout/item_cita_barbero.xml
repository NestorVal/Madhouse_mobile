<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="#2A2A2A"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/panelDetalles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@+id/panelEstado">

            <TextView
                android:id="@+id/tvItemCliente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cliente: Nestor Rodriguez"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="18sp"/>

            <TextView
                android:id="@+id/tvItemFechaHoraBarb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026-04-25 - 17:00"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/tvItemServicioBarb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Servicio: Corte de pelo"
                android:textColor="#AAAAAA"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/panelEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="end">

            <TextView
                android:id="@+id/tvItemEstadoBarb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="PENDIENTE"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="12sp"
                android:background="#555555" />

            <LinearLayout
                android:id="@+id/panelCompletarCita"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true">

                <CheckBox
                    android:id="@+id/checkCompletarCita"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#CCCCCC"
                    android:checked="false"
                    android:clickable="false" /> <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Marcar como completado"
                android:textColor="#CCCCCC"
                android:textSize="10sp"/>
            </LinearLayout>

        </LinearLayout>
    </RelativeLayout>
</androidx.cardview.widget.CardView>